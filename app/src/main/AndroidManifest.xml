<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:sharedUserId="android.uid.system">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:name=".HeyboardApp"
        android:persistent="true"
        android:theme="@style/Theme.Heyboard教学助手">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".RandomCallActivity"
            android:screenOrientation="landscape" />
        <activity
            android:name=".TimerActivity"
            android:screenOrientation="landscape" />
        <activity
            android:name=".SpotlightActivity"
            android:screenOrientation="landscape" />
        <activity
            android:name=".SubtitleActivity"
            android:screenOrientation="landscape" />
        <activity
            android:name=".SettingsActivity"
            android:screenOrientation="landscape" />
        <activity
            android:name=".automation.AutomationActivity"
            android:screenOrientation="landscape" />
        <activity
            android:name=".automation.ScenarioDetailActivity"
            android:screenOrientation="landscape" />
        <activity
            android:name=".automation.ActionDetailActivity"
            android:screenOrientation="landscape" />

        <receiver
            android:name=".automation.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".automation.FinishClassReceiver"
            android:process=":tool"
            android:exported="true">
            <intent-filter>
                <action android:name="com.h3c.action.FINISH_CLASS" />
                <action android:name="com.h3c.action.FINISH_CLASS_DONE" />
            </intent-filter>
        </receiver>

        <service
            android:name=".automation.HeyboardToolService"
            android:process=":tool"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="automation_tool" />
        </service>

        <service
            android:name=".SpotlightService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="screen_overlay" />
        </service>

        <service
            android:name=".SubtitleService"
            android:foregroundServiceType="microphone"
            android:exported="false" />
    </application>

</manifest>
